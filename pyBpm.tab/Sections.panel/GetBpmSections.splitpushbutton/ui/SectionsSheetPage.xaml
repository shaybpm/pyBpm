<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="גיליון">
    <!-- Button styles duplicated from SectionsResultsWindow.xaml: this Page loads
         inside a Frame, which isolates it from the Window's resources, and the
         row buttons use BasedOn (a parse-time StaticResource). Keep the two copies
         in sync when tuning the look. -->
    <Page.Resources>
        <Style x:Key="FlatButtonBase" TargetType="Button">
            <Setter Property="Foreground" Value="#2B2B2B" />
            <Setter Property="Background" Value="#F4F5F7" />
            <Setter Property="BorderBrush" Value="#CFD3DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E6F0FB" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5B9BD5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#CFE2F5" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3A7CBD" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F0F0F0" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#E2E2E2" />
                                <Setter Property="Foreground" Value="#AAAAAA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="TextButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="14,0,14,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#2D7DD2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="14,0,14,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="5"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2468B2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E568F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#BFC4CB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid FlowDirection="RightToLeft" Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <Button Content="בחר הכל" Click="SelectAll_Click"
                Style="{StaticResource TextButton}" />
            <Button Content="נקה בחירה" Click="UnselectAll_Click"
                Style="{StaticResource TextButton}" />
            <Button Content="נקה פילטרים" Click="ClearFilters_Click"
                Style="{StaticResource TextButton}" Margin="0,0,12,0" />
            <Button Content="חשב גיליון מחדש" Click="RecomputeSheet_Click"
                Style="{StaticResource PrimaryButton}" />
        </StackPanel>

        <DataGrid x:Name="DataGrid" Grid.Row="1"
            AutoGenerateColumns="False"
            HeadersVisibility="All"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            IsReadOnly="True"
            SelectionMode="Extended"
            SelectionChanged="SectionSelection_Changed"
            GridLinesVisibility="All">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding tier}" Value="green">
                            <Setter Property="Background" Value="#C8E6C9" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding tier}" Value="orange">
                            <Setter Property="Background" Value="#FFE0B2" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding tier}" Value="red">
                            <Setter Property="Background" Value="#FFCDD2" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding tier}" Value="empty">
                            <Setter Property="Background" Value="#EEEEEE" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- section name -->
                <DataGridTemplateColumn Header="חתך" SortMemberPath="section_name"
                    Width="*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="חתך" />
                                <TextBox Width="140"
                                    TextChanged="Filter_TextBox_TextChanged"
                                    Tag="section_name" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding section_name}"
                                VerticalAlignment="Center" Margin="4,0,4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- score -->
                <DataGridTemplateColumn Header="ציון" SortMemberPath="result_lower"
                    Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding score_text}"
                                VerticalAlignment="Center" Margin="4,0,4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- systems count (with empty/non-empty filter, D7) -->
                <DataGridTemplateColumn Header="מערכות" SortMemberPath="n" Width="130">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="מערכות" />
                                <ComboBox Width="110" Tag="has_systems"
                                    SelectionChanged="Filter_ComboBox_SelectionChanged">
                                    <ComboBoxItem Content="הכל" IsSelected="True" Tag="" />
                                    <ComboBoxItem Content="יש מערכות" Tag="True" />
                                    <ComboBoxItem Content="ריק" Tag="False" />
                                </ComboBox>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding n}"
                                VerticalAlignment="Center" Margin="4,0,4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- exists in host model -->
                <DataGridTemplateColumn Header="קיים" SortMemberPath="exists"
                    Width="120">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="קיים" />
                                <ComboBox Width="100" Tag="exists"
                                    SelectionChanged="Filter_ComboBox_SelectionChanged">
                                    <ComboBoxItem Content="הכל" IsSelected="True" Tag="" />
                                    <ComboBoxItem Content="קיים" Tag="True" />
                                    <ComboBoxItem Content="לא קיים" Tag="False" />
                                </ComboBox>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding exists_text}"
                                VerticalAlignment="Center" Margin="4,0,4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- per-row actions: create (when missing) / go-to + delete
                     (when it exists) + recompute. Buttons swap by {Binding
                     exists}. Each resolves its row via sender.DataContext. -->
                <DataGridTemplateColumn Header="פעולות" Width="230">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="יצירה" Click="Create_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TextButton}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding exists}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="מעבר" Click="GoTo_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TextButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding exists}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="מחיקה" Click="Delete_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TextButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding exists}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="&#x21BB;" ToolTip="חשב חתך זה מחדש"
                                    Click="Recompute_Click"
                                    Style="{StaticResource IconButton}"
                                    Margin="8,0,2,0" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" x:Name="StatusTextBlock" Margin="0,4,0,0"
            VerticalAlignment="Center" />
    </Grid>
</Page>
