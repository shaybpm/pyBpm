<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BPM - התאמת חתכים"
    MinHeight="300"
    MinWidth="520"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    Width="1100"
    Height="750"
    FlowDirection="LeftToRight">
    <Grid Margin="4">
        <Border Margin="4" BorderBrush="Gray" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Grid.ColumnSpan="3" BorderThickness="0,0,0,1"
                    BorderBrush="Gray">
                    <Grid Margin="8,6,8,6">
                        <TextBlock x:Name="TitleTextBlock" FontWeight="Bold"
                            FontSize="14" Text="BPM - התאמת חתכים"
                            FlowDirection="RightToLeft" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Navigation column: fixed top (Home + Settings + separator),
                     then a scrollable list of sheet buttons (D8). -->
                <Grid Grid.Row="1" Grid.Column="0" MinWidth="180">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" x:Name="NavTopPanel" Margin="4">
                        <!-- Home + Settings buttons + separator added in code -->
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="NavSheetsPanel" Margin="4">
                            <!-- One button per sheet added in code -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Vertical divider between nav and content -->
                <Border Grid.Row="1" Grid.Column="1" Background="Gray" Width="1" />

                <!-- Content host -->
                <Grid Grid.Row="1" Grid.Column="2" Margin="4">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
                        Navigated="MainFrame_Navigated" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
