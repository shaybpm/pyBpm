<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BPM - התאמת חתכים"
    Height="640"
    Width="580"
    WindowStartupLocation="CenterScreen"
    MinWidth="480"
    MinHeight="420">

    <Grid FlowDirection="RightToLeft" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Sheet scope -->
        <Border Grid.Row="0" BorderThickness="1" BorderBrush="Gray" Padding="6"
            Margin="0 0 0 6">
            <StackPanel>
                <TextBlock Text="גיליונות לחישוב:" FontWeight="Bold" Margin="0 0 0 4" />
                <ScrollViewer MaxHeight="90" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="SheetScopePanel" />
                </ScrollViewer>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0 6 0 0">
                    <Button x:Name="RecomputeAllButton" Content="חשב הכל מחדש"
                        Click="recompute_all_click" Padding="10 3 10 3"
                        Margin="0 0 6 0" />
                    <Button x:Name="RecomputeButton" Content="החל גיליונות"
                        Click="recompute_click" Padding="10 3 10 3" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search + sort -->
        <Grid Grid.Row="1" Margin="0 0 0 6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SearchTextBox" Margin="0 0 4 0"
                TextChanged="search_changed" />
            <ComboBox Grid.Column="1" x:Name="SortComboBox" Margin="4 0 0 0"
                SelectionChanged="sort_changed" />
        </Grid>

        <!-- Results (header is rendered as the first row) -->
        <Border Grid.Row="2" BorderThickness="1" BorderBrush="Gray">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultsPanel" Margin="2" />
            </ScrollViewer>
        </Border>

        <!-- Summary -->
        <TextBlock Grid.Row="3" x:Name="SummaryText" Margin="0 6 0 0"
            FontSize="12" TextWrapping="Wrap" />

    </Grid>
</Window>
