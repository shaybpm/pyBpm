<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="הגדרות">
    <Grid FlowDirection="RightToLeft" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8"
            FontSize="13" FontWeight="Bold"
            Text="בחר את הפילטרים של הדיסציפלינות הרלוונטיות עבור התאמת החתכים. שינוי הבחירה מאפס את החישובים." />

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="groups_panel" Margin="6" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Padding="0,6,0,6" Margin="0,6,0,6"
            BorderThickness="0,1,0,1" BorderBrush="Gray">
            <StackPanel Orientation="Horizontal">
                <Button Content="סמן הכל" Click="select_all_click"
                    Padding="10,3,10,3" Margin="0,0,6,0" />
                <Button Content="נקה הכל" Click="clear_all_click"
                    Padding="10,3,10,3" />
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Content="שמור בחירה" Click="save_click"
            Padding="14,4,14,4" HorizontalAlignment="Right" FontWeight="Bold" />
    </Grid>
</Page>
