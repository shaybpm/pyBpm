<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="בחירת פילטרים לפי דיסציפלינה"
    Height="520"
    Width="440"
    WindowStartupLocation="CenterScreen"
    MinWidth="380"
    MinHeight="400"
    Topmost="True">

    <Grid FlowDirection="RightToLeft" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0 0 0 8"
            FontSize="13" FontWeight="Bold">
            <Run Text="בחר את הפילטרים של הדיסציפלינות הרלוונטיות עבור התאמת החתכים." />
        </TextBlock>

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="groups_panel" Margin="4" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Padding="0 6 0 6" Margin="0 6 0 6"
            BorderThickness="0 1 0 1" BorderBrush="Gray">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="select_all_click" Content="סמן הכל"
                    Margin="0 0 4 0" />
                <Button Grid.Column="1" Click="clear_all_click" Content="נקה הכל"
                    Margin="4 0 0 0" />
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="ok_btn_click" Content="אישור"
                Margin="0 0 4 0" />
            <Button Grid.Column="1" Click="cancel_btn_click" Content="ביטול"
                Margin="4 0 0 0" />
        </Grid>

    </Grid>
</Window>
