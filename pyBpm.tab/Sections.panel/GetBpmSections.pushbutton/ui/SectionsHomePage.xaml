<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ראשי">
    <Grid FlowDirection="RightToLeft" Margin="18">
        <StackPanel VerticalAlignment="Top">
            <TextBlock x:Name="HeadingTextBlock" FontSize="16" FontWeight="Bold"
                Margin="0,0,0,12" TextWrapping="Wrap" />
            <TextBlock x:Name="CountsTextBlock" FontSize="14"
                Margin="0,0,0,12" TextWrapping="Wrap" />
            <TextBlock x:Name="HintTextBlock" FontSize="13" Foreground="Gray"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
